      "miniLesson": {
        "title": "Mixed Two-Step",
        "paragraph": "Two-step equations may involve **fractions** or **decimals**, but the strategy is the same: undo the addition first, then undo the multiplication or division. For $\\frac{x}{2} + 1 = 4$, subtract 1 to get $\\frac{x}{2} = 3$, then multiply by 2 to get $x = 6$.",
        "example": {
          "prompt": "Solve for $x$: $\\frac{x}{2} + 1 = 4$",
          "interaction": {
            "type": "numeric",
