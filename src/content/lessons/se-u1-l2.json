      "miniLesson": {
        "title": "Negative Answers",
        "paragraph": "Two-step equations can lead to **negative** answers. Subtract the constant first, then divide, and **keep the negative sign**. For $2x + 8 = 2$, subtract 8 to get $2x = -6$, then divide by 2 to get $x = -3$.",
        "example": {
          "prompt": "Solve for $x$: $2x + 8 = 2$",
          "interaction": {
            "type": "numeric",
            "data": {
              "placeholder": "Value of x",
              "validation": { "type": "numeric", "value": -3 }
            }
          },
          "explanation": "Subtract 8: $2x = -6$. Divide by 2: $x = -3$."
        }
      }
