      "miniLesson": {
        "title": "Two-Step Equations",
        "paragraph": "When an equation has both a multiplied coefficient and an added constant, **undo the addition first**, then undo the multiplication. For $2x + 1 = 7$, subtract 1 to get $2x = 6$, then divide by 2 to get $x = 3$. Always reverse the operations in the opposite order.",
        "example": {
          "prompt": "Solve for $x$: $2x + 1 = 7$",
          "interaction": {
            "type": "numeric",
            "data": {
              "placeholder": "Value of x",
              "validation": { "type": "numeric", "value": 3 }
            }
          },
          "explanation": "Subtract 1: $2x = 6$. Divide by 2: $x = 3$."
        }
      }
    },
