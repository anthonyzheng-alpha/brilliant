      "miniLesson": {
        "title": "Undo Multiplication",
        "paragraph": "When a variable is **multiplied** by a number, undo it by **dividing both sides** by that number. For $2x = 10$, divide both sides by 2 to get $x = 5$. The goal is to leave the variable alone on one side.",
        "example": {
          "prompt": "Solve for $x$: $2x = 10$",
          "interaction": {
            "type": "numeric",
            "data": {
              "placeholder": "Value of x",
              "validation": { "type": "numeric", "value": 5 }
            }
          },
          "explanation": "Divide both sides by 2: $x = 10 \\div 2 = 5$."
        }
      }
    },
