      "miniLesson": {
        "title": "Undo Division",
        "paragraph": "When a variable is **divided** by a number, undo it by **multiplying both sides** by that number. For $\\frac{x}{2} = 3$, multiply both sides by 2 to get $x = 6$. Multiplying reverses the division.",
        "example": {
          "prompt": "Solve for $x$: $\\frac{x}{2} = 3$",
          "interaction": {
            "type": "multiple-choice",
            "data": {
              "options": [
                { "id": "a", "label": "$x = 6$" },
                { "id": "b", "label": "$x = 5$", "whyWrong": "This adds 2 to 3 instead of multiplying by it." },
                { "id": "c", "label": "$x = \\frac{3}{2}$", "whyWrong": "This divides by 2 instead of multiplying by it." }
              ],
              "correctOptionId": "a"
            }
          },
          "explanation": "Multiply both sides by 2: $x = 3 \\times 2 = 6$."
        }
      }
    },
